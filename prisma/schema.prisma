generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN              // System-wide administrator
  OPS                // Operations manager (organization-scoped)
  SUPPORT            // Support worker (property-scoped)
  VIEWER             // Read-only access
  COMPLIANCE_OFFICER // Compliance and audit management
  ORG_ADMIN          // Organization administrator (org-scoped admin)
}

enum SubscriptionTier {
  FREE
  BASIC
  PROFESSIONAL
  ENTERPRISE
}

enum TenantStatus {
  PENDING
  READY_FOR_TENANCY
  ACTIVE
  NOTICE_GIVEN
  MOVED_OUT
}

enum DocumentType {
  PROOF_OF_ID
  PROOF_OF_INCOME
  SUPPORT_PLAN
  MEDICAL
  AUTHORIZATION_FORM
  CONFIDENTIALITY_WAIVER
  FIRE_EVACUATION
  LICENCE_AGREEMENT
  MISSING_PERSON_FORM
  NIL_INCOME_FORM
  SERVICE_CHARGE_AGREEMENT
  SUPPORT_AGREEMENT
  SUPPORT_NEEDS_ASSESSMENT
  PHOTO_ID_CONSENT
  OTHER
}

enum Ethnicity {
  WHITE_BRITISH
  WHITE_IRISH
  WHITE_OTHER
  MIXED_WHITE_BLACK_CARIBBEAN
  MIXED_WHITE_BLACK_AFRICAN
  MIXED_WHITE_ASIAN
  MIXED_OTHER
  ASIAN_INDIAN
  ASIAN_PAKISTANI
  ASIAN_BANGLADESHI
  ASIAN_OTHER
  BLACK_CARIBBEAN
  BLACK_AFRICAN
  BLACK_OTHER
  CHINESE
  OTHER
  PREFER_NOT_TO_SAY
}

enum Religion {
  NO_RELIGION
  CHRISTIAN
  MUSLIM
  HINDU
  SIKH
  JEWISH
  BUDDHIST
  OTHER
  PREFER_NOT_TO_SAY
}

enum SexualOrientation {
  HETEROSEXUAL
  HOMOSEXUAL
  LESBIAN
  BISEXUAL
  TRANSGENDER
  OTHER
  PREFER_NOT_TO_SAY
}

enum IncomeSource {
  ESA
  DLA
  JSA
  UNIVERSAL_CREDIT
  HOUSING_BENEFIT
  NIL_INCOME
  EMPLOYMENT
  OTHER
}

enum DocumentStatus {
  PENDING
  VERIFIED
  REJECTED
}

enum ContactType {
  IN_PERSON
  PHONE_CALL
}

enum AttendanceStatus {
  PRESENT
  AUTHORISED_NON_ATTENDANCE
  DID_NOT_ATTEND
}

model Organization {
  id               String           @id @default(uuid())
  name             String
  subdomain        String           @unique
  contactEmail     String
  contactPhone     String?
  address          String?
  postcode         String?
  subscriptionTier SubscriptionTier @default(BASIC)
  billingContact   String?
  billingEmail     String?
  billingAddress   String?
  paymentMethod    String?          // e.g., "Credit Card ending in 1234", "Bank Transfer"
  isActive         Boolean          @default(true)
  settings         Json?            // Branding, configuration, preferences
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  users        User[]
  properties   Property[]
  residents    Tenant[]          // Will be renamed to Resident
  documents    Document[]
  auditLogs    AuditLog[]
  staff        Staff[]
  incidents    Incident[]
  compliance   Compliance[]
  supportNotes SupportNote[]

  @@map("organizations")
}

model User {
  id              String   @id @default(uuid())
  organizationId  String
  email           String   @unique
  password        String
  firstName       String
  lastName        String
  role            Role     @default(VIEWER)
  isPlatformAdmin Boolean  @default(false) // Orbixio LTD staff with cross-org access
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  organization        Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  
  // Support workers can be assigned to properties
  propertyAssignments Assignment[]
  auditLogs           AuditLog[]
  documentsUploaded   Document[]   @relation("DocumentUploader")
  documentsVerified   Document[]   @relation("DocumentVerifier")
  tenanciesEnded      Tenancy[]    @relation("TenancyEndedBy")
  incidentsReported   Incident[]   @relation("IncidentReporter")
  supportNotes        SupportNote[] @relation("SupportWorker")

  @@index([organizationId])
  @@map("users")
}

model Property {
  id                  String   @id @default(uuid())
  organizationId      String
  name                String
  address             String
  postcode            String
  totalUnits          Int
  description         String?
  serviceChargeAmount Decimal? @db.Decimal(10, 2)
  serviceChargeNotes  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  rooms        Room[]
  assignments  Assignment[]

  @@index([organizationId])
  @@map("properties")
}

model Room {
  id         String   @id @default(uuid())
  propertyId String
  roomNumber String
  capacity   Int      @default(1)
  floor      Int?
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  property   Property   @relation(fields: [propertyId], references: [id], onDelete: Restrict)
  tenancies  Tenancy[]

  @@unique([propertyId, roomNumber])
  @@map("rooms")
}

model Assignment {
  id         String   @id @default(uuid())
  userId     String
  propertyId String
  startDate  DateTime @default(now())
  endDate    DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  property   Property @relation(fields: [propertyId], references: [id], onDelete: Cascade)

  @@map("assignments")
}

model Tenant {
  id                      String       @id @default(uuid())
  organizationId          String
  firstName               String
  lastName                String
  email                   String?
  phone                   String?
  dateOfBirth             DateTime
  nationalInsuranceNumber String?
  status                  TenantStatus @default(PENDING)
  createdAt               DateTime     @default(now())
  updatedAt               DateTime     @updatedAt

  organization        Organization             @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenancies           Tenancy[]
  documents           Document[]
  profile             TenantProfile?
  emergencyContacts   TenantEmergencyContact[]
  finance             TenantFinance?
  riskAssessment      TenantRiskAssessment?
  supportPlan         TenantSupportPlan?
  consents            TenantConsent?
  missingPersonProfile MissingPersonProfile?
  inventoryLogs       InventoryLog[]
  serviceChargeRecords ServiceChargeRecord[]
  incidents           Incident[]
  supportNotes        SupportNote[]

  @@index([organizationId])
  @@map("tenants")
}

model Tenancy {
  id                  String    @id @default(uuid())
  tenantId            String
  roomId              String
  startDate           DateTime
  endDate             DateTime?
  isActive            Boolean   @default(true)
  serviceChargeAmount Decimal?  @db.Decimal(10, 2)
  endReason           String?
  endNotes            String?
  endedById           String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  tenant    Tenant    @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  room      Room      @relation(fields: [roomId], references: [id], onDelete: Restrict)
  endedBy   User?     @relation("TenancyEndedBy", fields: [endedById], references: [id], onDelete: SetNull)

  @@map("tenancies")
}

model Document {
  id                String         @id @default(uuid())
  organizationId    String
  tenantId          String
  type              DocumentType
  status            DocumentStatus @default(PENDING)
  fileName          String
  fileSize          Int
  mimeType          String
  sha256Hash        String
  uploadedById      String
  uploadedAt        DateTime       @default(now())
  verifiedById      String?
  verifiedAt        DateTime?
  verificationNotes String?
  rejectionReason   String?
  isMandatory       Boolean        @default(false)
  
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant       Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  uploadedBy   User         @relation("DocumentUploader", fields: [uploadedById], references: [id])
  verifiedBy   User?        @relation("DocumentVerifier", fields: [verifiedById], references: [id])
  blob         DocumentBlob?

  @@index([organizationId])
  @@index([tenantId])
  @@index([sha256Hash])
  @@map("documents")
}

model DocumentBlob {
  id            String   @id @default(uuid())
  documentId    String   @unique
  encryptedData Bytes
  iv            String
  authTag       String
  createdAt     DateTime @default(now())

  document      Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_blobs")
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  userId         String
  action         String
  entityType     String
  entityId       String?
  changes        Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@index([organizationId])
  @@index([userId])
  @@index([entityType, entityId])
  @@index([createdAt])
  @@map("audit_logs")
}

model TenantProfile {
  id                   String              @id @default(uuid())
  tenantId             String              @unique
  title                String?
  otherNames           String?
  placeOfBirth         String?
  previousAddress      String?
  nationality          String?
  languagesSpoken      String?
  ethnicity            Ethnicity?
  religion             Religion?
  sexualOrientation    SexualOrientation?
  maritalStatus        String?
  currentSituation     String?
  homelessnessReason   String?
  disabilities         String?
  communicationNeeds   String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  tenant               Tenant              @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_profiles")
}

model TenantEmergencyContact {
  id            String   @id @default(uuid())
  tenantId      String
  name          String
  relationship  String
  address       String?
  phone         String?
  mobile        String?
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  tenant        Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_emergency_contacts")
}

model TenantFinance {
  id                       String        @id @default(uuid())
  tenantId                 String        @unique
  incomeSource             IncomeSource?
  benefitType              String?
  benefitAmount            Decimal?      @db.Decimal(10, 2)
  benefitFrequency         String?
  hasNilIncome             Boolean       @default(false)
  nilIncomeExplanation     String?       @db.Text
  councilAuthorizationAgreed Boolean     @default(false)
  employmentDetails        String?
  debtDetails              String?
  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @updatedAt

  tenant                   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_finance")
}

model TenantRiskAssessment {
  id                      String   @id @default(uuid())
  tenantId                String   @unique
  hasCriminalRecord       Boolean  @default(false)
  criminalRecordDetails   String?
  hasDrugUse              Boolean  @default(false)
  drugUseDetails          String?
  hasAlcoholIssue         Boolean  @default(false)
  alcoholDetails          String?
  hasSuicidalThoughts     Boolean  @default(false)
  suicidalThoughtsDetails String?
  hasSelfHarmHistory      Boolean  @default(false)
  selfHarmDetails         String?
  hasMentalHealth         Boolean  @default(false)
  mentalHealthDetails     String?
  mentalHealthDiagnosis   String?
  prescribedMedication    String?
  hasSocialWorker         Boolean  @default(false)
  socialWorkerDetails     String?
  hasProbationOfficer     Boolean  @default(false)
  probationOfficerName    String?
  probationOfficerPhone   String?
  probationDetails        String?
  doctorName              String?
  doctorPhone             String?
  gpPractice              String?
  cpnName                 String?
  cpnPhone                String?
  psychiatristName        String?
  psychiatristPhone       String?
  riskNotes               String?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  tenant                  Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_risk_assessments")
}

model TenantSupportPlan {
  id                  String   @id @default(uuid())
  tenantId            String   @unique
  supportNeeds        String?
  supportGoals        String?
  budgetPlanAgreed    Boolean  @default(false)
  employmentSupport   Boolean  @default(false)
  lifeSkillsSupport   Boolean  @default(false)
  healthSupport       Boolean  @default(false)
  reviewFrequency     String?
  lastReviewDate      DateTime?
  nextReviewDate      DateTime?
  supportWorkerNotes  String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  tenant              Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_support_plans")
}

model TenantConsent {
  id                           String    @id @default(uuid())
  tenantId                     String    @unique
  authorizationFormSigned      Boolean   @default(false)
  authorizationFormSignedAt    DateTime?
  authorizationFormSignature   String?   // Base64 encoded signature image
  confidentialityWaiverSigned  Boolean   @default(false)
  confidentialityWaiverSignedAt DateTime?
  confidentialityWaiverSignature String?
  fireEvacuationAcknowledged   Boolean   @default(false)
  fireEvacuationAcknowledgedAt DateTime?
  fireEvacuationSignature      String?
  licenceAgreementSigned       Boolean   @default(false)
  licenceAgreementSignedAt     DateTime?
  licenceAgreementSignature    String?
  missingPersonFormSigned      Boolean   @default(false)
  missingPersonFormSignedAt    DateTime?
  missingPersonFormSignature   String?
  nilIncomeFormSigned          Boolean   @default(false)
  nilIncomeFormSignedAt        DateTime?
  nilIncomeFormSignature       String?
  serviceChargeAgreementSigned Boolean   @default(false)
  serviceChargeAgreementSignedAt DateTime?
  serviceChargeAgreementSignature String?
  supportAgreementSigned       Boolean   @default(false)
  supportAgreementSignedAt     DateTime?
  supportAgreementSignature    String?
  supportNeedsAssessmentSigned Boolean   @default(false)
  supportNeedsAssessmentSignedAt DateTime?
  supportNeedsAssessmentSignature String?
  photoIdConsentGiven          Boolean   @default(false)
  photoIdConsentGivenAt        DateTime?
  photoIdConsentType           String?   // "PROVIDED_ID", "PERMISSION_TO_PHOTOGRAPH", "DECLINE"
  photoIdConsentSignature      String?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  tenant                       Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("tenant_consents")
}

model MissingPersonProfile {
  id                    String   @id @default(uuid())
  tenantId              String   @unique
  height                String?
  shoeSize              String?
  clothingSize          String?
  build                 String?  // e.g., "small", "medium", "large"
  distinguishingMarks   String?  @db.Text // Tattoos, birthmarks, scars
  skinTone              String?
  hairColor             String?
  eyeColor              String?
  vehicleDetails        String?  @db.Text // Make, color, registration
  potentialRiskDetails  String?  @db.Text
  likelyDestinations    String?  @db.Text // Areas/places they might visit
  employerOrCollege     String?  // Name, address, contact
  additionalNotes       String?  @db.Text
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@map("missing_person_profiles")
}

model InventoryLog {
  id                    String   @id @default(uuid())
  tenantId              String
  roomId                String?
  checkInDate           DateTime @default(now())
  checkOutDate          DateTime?
  
  // Bedding provided
  hasQuilt              Boolean  @default(false)
  hasPillow             Boolean  @default(false)
  hasDuvetCover         Boolean  @default(false)
  hasFittedSheet        Boolean  @default(false)
  hasWindowDressing     Boolean  @default(false)
  
  // Furniture provided
  hasWardrobe           Boolean  @default(false)
  hasChestOfDrawers     Boolean  @default(false)
  hasBed                Boolean  @default(false)
  hasMattress           Boolean  @default(false)
  keysIssued            Int      @default(0)
  
  // Room condition at check-in
  isCleanAndTidy        Boolean  @default(false)
  floorWallGoodCondition Boolean  @default(false)
  electricsWorking      Boolean  @default(false)
  structureGoodCondition Boolean  @default(false)
  
  // Check-out condition
  checkOutClean         Boolean?
  checkOutDamages       String?  @db.Text
  
  notes                 String?  @db.Text
  conditionPhotos       Json?    // Array of photo URLs/paths
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("inventory_logs")
}

model ServiceChargeRecord {
  id                    String   @id @default(uuid())
  tenantId              String
  weekStartDate         DateTime
  weekEndDate           DateTime
  chargeAmount          Decimal  @db.Decimal(10, 2) // e.g., £20.00 per week
  isPaid                Boolean  @default(false)
  paidAt                DateTime?
  paidAmount            Decimal? @db.Decimal(10, 2)
  paymentMethod         String?  // "Cash", "Bank Transfer", "Benefits"
  notes                 String?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  tenant                Tenant   @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([weekStartDate])
  @@index([isPaid])
  @@map("service_charge_records")
}

// New models for multi-tenant SaaS features

enum IncidentType {
  SAFEGUARDING
  MEDICATION
  ACCIDENT
  NEAR_MISS
  BEHAVIORAL
  PROPERTY_DAMAGE
  MISSING_PERSON
  OTHER
}

enum IncidentSeverity {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum IncidentStatus {
  REPORTED
  UNDER_INVESTIGATION
  RESOLVED
  CLOSED
}

enum ComplianceStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  OVERDUE
}

enum AuditType {
  CQC_INSPECTION
  INTERNAL_AUDIT
  FIRE_SAFETY
  HEALTH_SAFETY
  SAFEGUARDING
  MEDICATION
  GDPR_COMPLIANCE
  OTHER
}

model Staff {
  id               String    @id @default(uuid())
  organizationId   String
  firstName        String
  lastName         String
  email            String?
  phone            String?
  jobTitle         String
  dbsNumber        String?
  dbsExpiryDate    DateTime?
  dbsCheckDate     DateTime?
  trainingRecords  Json?     // Array of {courseName, completedDate, expiryDate}
  startDate        DateTime
  endDate          DateTime?
  isActive         Boolean   @default(true)
  emergencyContact Json?     // {name, relationship, phone}
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([dbsExpiryDate])
  @@map("staff")
}

model Incident {
  id              String           @id @default(uuid())
  organizationId  String
  residentId      String?          // Optional - incident might not involve a resident
  reportedById    String
  incidentType    IncidentType
  severity        IncidentSeverity
  status          IncidentStatus   @default(REPORTED)
  title           String
  description     String
  location        String?
  witnessDetails  String?
  actionsTaken    String?
  followUpRequired Boolean         @default(false)
  followUpNotes   String?
  reportedAt      DateTime         @default(now())
  occurredAt      DateTime?
  resolvedAt      DateTime?
  resolvedBy      String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  resident     Tenant?      @relation(fields: [residentId], references: [id], onDelete: SetNull)
  reporter     User         @relation("IncidentReporter", fields: [reportedById], references: [id])

  @@index([organizationId])
  @@index([residentId])
  @@index([reportedById])
  @@index([status])
  @@index([reportedAt])
  @@map("incidents")
}

model Compliance {
  id                 String           @id @default(uuid())
  organizationId     String
  auditType          AuditType
  status             ComplianceStatus @default(PENDING)
  title              String
  description        String?
  auditDate          DateTime
  auditorName        String?
  auditorOrganization String?
  findings           String?          // Simplified to text for MVP
  score              Int?             // Overall score if applicable
  actionPlan         String?          // Simplified to text for MVP
  evidence           Json?            // Array of {description, uploadedAt, uploadedBy}
  dueDate            DateTime?
  completedAt        DateTime?
  completedBy        String?
  notes              String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([auditType])
  @@index([status])
  @@index([auditDate])
  @@map("compliance")
}

model SupportNote {
  id                             String           @id @default(uuid())
  organizationId                 String
  tenantId                       String
  supportWorkerId                String
  sessionDate                    DateTime
  contactType                    ContactType
  attendanceStatus               AttendanceStatus
  
  // Support Criteria Sections
  economicWellbeingNotes         String?          @db.Text // Banking, Budgeting, Debt, Benefits
  enjoyAchieveNotes              String?          @db.Text // Employment, Education, Social networks, Volunteering
  healthNotes                    String?          @db.Text // Healthcare, Physical health, Substance misuse
  staySafeNotes                  String?          @db.Text // Living conditions, Life skills, Risk reduction
  positiveContributionNotes      String?          @db.Text // Anti-social behaviour, Probation, Relationships
  
  // Additional sections
  specificSupportNeeds           String?          @db.Text
  sessionComments                String?          @db.Text
  
  // Signatures
  clientSignature                String?          // Digital signature or name
  supportWorkerSignature         String?          // Digital signature or name
  
  // Next session
  nextSessionDate                DateTime?
  
  createdAt                      DateTime         @default(now())
  updatedAt                      DateTime         @updatedAt

  // Relations
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  tenant          Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  supportWorker   User         @relation("SupportWorker", fields: [supportWorkerId], references: [id])

  @@index([organizationId])
  @@index([tenantId])
  @@index([supportWorkerId])
  @@index([sessionDate])
  @@map("support_notes")
}
